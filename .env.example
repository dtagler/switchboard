# SwitchBoard runtime configuration template.
#
# Copy this file to `.env` (gitignored) and fill in your Nuphy's Bluetooth MAC.
# The app loads it at startup from (in order of precedence):
#   1. The SWITCHBOARD_NUPHY_BD_ADDR environment variable
#   2. `.env` next to switchboard.exe (typical install layout)
#   3. `.env` in the current working directory (dev convenience)
#
# If unset or unparseable, the app logs an error and runs with BLE
# monitoring disabled (internal keyboard stays enabled — fail-open).
# (Diagnostics live in `%LOCALAPPDATA%\switchboard\switchboard.log` —
# there is no balloon notification in v0.1.)
#
# Accepted formats (case-insensitive):
#   0xAABBCCDDEEFF
#   AABBCCDDEEFF
#   AA:BB:CC:DD:EE:FF
#   AA-BB-CC-DD-EE-FF
#
# To find your Nuphy's MAC:
#   Settings → Bluetooth & devices → Nuphy → Properties → Bluetooth address
#
# DO NOT commit your real `.env`. The MAC is owner-specific PII and persists
# across reinstalls.

SWITCHBOARD_NUPHY_BD_ADDR=AA:BB:CC:DD:EE:FF
